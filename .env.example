# Required for live Google Maps / Places results.
GOOGLE_PLACES_API_KEY=

# Optional Google Apps Script webhook for pushing rows into Google Sheets.
GOOGLE_SHEETS_WEBHOOK_URL=

# Recommended for teammate access on Railway.
APP_USERNAME=schild
APP_PASSWORD=change-this-password

# Railway volume mount. Locally you can omit this and the app uses ./data.
DATA_DIR=/app/data
