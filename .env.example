APP_ENV=development
APP_NAME=Schild Inc CRM MVP
APP_BASE_URL=http://localhost:8000
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/schildinc
ADMIN_USERNAME=schild
ADMIN_PASSWORD=change-me

GOOGLE_PLACES_API_KEY=
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
KLAVIYO_PRIVATE_API_KEY=
KLAVIYO_API_REVISION=2026-04-15
KLAVIYO_DEFAULT_LIST_ID=
KLAVIYO_DEFAULT_LIST_NAME=

MAIL_PROVIDER=console
MAIL_FROM=noreply@schildinc.com
REPLY_TO_EMAIL=sales@schildinc.com
SENDER_NAME=Schild Inc Team
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

CAMPAIGN_ACTIVE=true
DAILY_SEND_LIMIT=25
DEFAULT_QUEUE_SIZE=25
SEND_WINDOW_START=08:00
SEND_WINDOW_END=17:30
OUTREACH_COOLDOWN_DAYS=14
PREVIEW_CONTACT_COUNT=20

PLAYWRIGHT_TIMEOUT_MS=12000
OFFICIAL_INSTAGRAM_HANDLE=@schildinc
OFFICIAL_LINKEDIN_URL=https://www.linkedin.com/company/schild-inc/

UNSUBSCRIBE_SECRET=change-me-too

# ── Gmail email engine ──────────────────────────────────────────────
# Create an OAuth 2.0 "Web application" client at
# https://console.cloud.google.com/apis/credentials and enable the Gmail API.
# Authorized redirect URI must be: {APP_BASE_URL}/emails/gmail/callback
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
# The verified "Send mail as" alias (Gmail -> Settings -> Accounts -> Send mail as)
GMAIL_SEND_AS=sales@schildinc.com
GMAIL_SENDER_NAME=Schild Inc
GMAIL_DAILY_LIMIT=80
GMAIL_SEND_SPACING_SECONDS=8
EMAIL_SENDER_ENABLED=true
EMAIL_SENDER_INTERVAL=60
GMAIL_INBOUND_ENABLED=true
GMAIL_INBOUND_INTERVAL=120
GMAIL_INBOUND_LOOKBACK_DAYS=3

# ── WhatsApp Business Cloud API (direct Meta) ───────────────────────
# Meta → WhatsApp → API setup. Register webhook callback URL:
#   {APP_BASE_URL}/webhooks/whatsapp   with the verify token below.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=choose-a-random-string
WHATSAPP_APP_SECRET=
WHATSAPP_API_VERSION=v21.0
WHATSAPP_DEFAULT_LANG=en
