# Required for live Google Maps / Places results.
GOOGLE_PLACES_API_KEY=

# Optional Google Apps Script webhook for pushing rows into Google Sheets.
GOOGLE_SHEETS_WEBHOOK_URL=

# Optional webhook for sending outreach emails from inside the app.
# Useful with Make, Zapier, Apps Script Gmail, Resend worker, or your own endpoint.
EMAIL_SEND_WEBHOOK_URL=
EMAIL_SEND_WEBHOOK_SECRET=

# Optional OpenAI draft regeneration. When set, "Generate again" can rewrite drafts
# from a user command with the Responses API.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5

# Optional direct Trengo integration. If these are set, the dashboard sends through
# Trengo first and opens the Trengo workspace after creating the message.
TRENGO_API_TOKEN=
TRENGO_EMAIL_CHANNEL_ID=
TRENGO_APP_URL=https://app.trengo.com

# Recommended for teammate access on Railway.
APP_USERNAME=schild
APP_PASSWORD=change-this-password

# Railway volume mount. Locally you can omit this and the app uses ./data.
DATA_DIR=/app/data
